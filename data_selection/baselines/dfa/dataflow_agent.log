            max_score=10000.0,
            device='cuda',
            model_cache_dir='./dataflow_cache',
            max_length=512
        )

        # Initialize SuperfilteringFilter
        self.superfiltering_filter = SuperfilteringFilter(
            min_score=0.0,
            max_score=1.0,
            device='cuda',
            model_cache_dir='./dataflow_cache',
            max_length=512
        )

    def run(self, storage):
        # Run DeitaQualityFilter
        deita_output_key = self.deita_quality_filter.run(
            storage=storage.step(),
            input_instruction_key='instruction',
            input_output_key='output',
            output_key='DeitaQualityScore'
        )

        # Run SuperfilteringFilter
        superfiltering_output_key = self.superfiltering_filter.run(
            storage=storage.step(),
            input_instruction_key='instruction',
            input_input_key='input',
            input_output_key='output',
            output_key='SuperfilteringScore'
        )

        return {
            "DeitaQualityFilterOutput": deita_output_key,
            "SuperfilteringFilterOutput": superfiltering_output_key
        } (The existing DataFilteringPipeline class definition)
