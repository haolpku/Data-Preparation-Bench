from dataflow.operators.text_sft.filter.deita_quality_filter import DeitaQualityFilter
from dataflow.operators.text_sft.filter.superfiltering_filter import SuperfilteringFilter

class DataFilteringPipeline:
    def __init__(self, device='cuda', model_cache_dir='./dataflow_cache'):
        # Initialize operators
        self.deita_quality_filter = DeitaQualityFilter(device=device, model_cache_dir=model_cache_dir)
        self.superfiltering_filter = SuperfilteringFilter(device=device, model_cache_dir=model_cache_dir)

    def run(self, storage):
        # Sequential calls to operators
        self.deita_quality_filter.run(storage.step(), input_instruction_key='instruction', input_output_key='output')
        self.superfiltering_filter.run(storage.step(), input_instruction_key='instruction', input_input_key='input', input_output_key='output')

if __name__ == "__main__":
