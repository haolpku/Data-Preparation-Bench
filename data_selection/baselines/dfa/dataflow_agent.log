import os
from dataflow.utils.registry import OPERATOR_REGISTRY
if hasattr(OPERATOR_REGISTRY, "_get_all"):
    OPERATOR_REGISTRY._get_all()

from dataflow.utils.storage import FileStorage
from dataflow.operators.text_sft.filter.deita_quality_filter import DeitaQualityFilter
from dataflow.operators.text_sft.filter.superfiltering_filter import SuperfilteringFilter

class DataFilteringPipeline:
    def __init__(self, min_score_deita=2.5, max_score_deita=10000.0, min_score_super=0.0, max_score_super=1.0, device='cuda', model_cache_dir='./dataflow_cache', max_length=512):
        # Initialize operators
        self.deita_quality_filter = DeitaQualityFilter(min_score=min_score_deita, max_score=max_score_deita, device=device, model_cache_dir=model_cache_dir, max_length=max_length)
        self.superfiltering_filter = SuperfilteringFilter(min_score=min_score_super, max_score=max_score_super, device=device, model_cache_dir=model_cache_dir, max_length=max_length)

    def run(self, storage):
        # Sequential calls to operators
        self.deita_quality_filter.run(storage.step(), input_instruction_key='instruction', input_output_key='output', output_key='DeitaQualityScore')
        self.superfiltering_filter.run(storage.step(), input_instruction_key='instruction', input_input_key='input', input_output_key='output', output_key='SuperfilteringScore')

if __name__ == "__main__":
    storage = FileStorage(first_entry_file_name="/home/hxy/dcai/data_selection/dataset/dfa_databricks-dolly_sample.jsonl", cache_path="/home/hxy/dcai/data_selection/output/data_selection/dataset_dfa_20260404_060356/", file_name_prefix="dataflow_cache_step", cache_type="jsonl")
    pipeline = DataFilteringPipeline()
    pipeline.run(storage)
