    @staticmethod
    def get_desc(lang: str = "zh"):
        if lang == "zh":
            return (
                "基于DeitaQualityScorer打分器的得分对数据进行过滤。使用基于Llama模型的Deita指令质量评估器，评估指令的质量高低。\n\n"
                "初始化参数：\n"
                "- min_score: 最低分数阈值，默认为2.5\n"
                "- max_score: 最高分数阈值，默认为10000.0\n"
                "- device: 运行设备，默认为'cuda'\n"
