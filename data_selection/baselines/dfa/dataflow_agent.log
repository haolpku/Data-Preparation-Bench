    cache_path="/home/hxy/dcai/data_selection/output/data_selection/dataset_dfa_20260404_060505/",
    file_name_prefix="dataflow_cache_step",
    cache_type="jsonl"
)

# Run the pipeline
pipeline = DataFilteringPipeline()
pipeline.run(storage)
