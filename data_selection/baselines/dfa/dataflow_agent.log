                "- input_output_key：输出字段名，默认为'output'\n"
                "- output_key：过滤结果分数字段名，默认为'SuperfilteringScore'\n"
                "输出参数：\n"
                "- 过滤后的DataFrame，仅保留分数在[min_score, max_score]范围内的样本\n"
                "- 返回包含过滤结果分数字段名的列表，用于后续算子引用"
            )
        elif lang == "en":
            return (
