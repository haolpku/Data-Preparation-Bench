)

class DataFilteringPipeline:
    def __init__(self, min_score_deita=2.5, max_score_deita=10000.0, min_score_super=0.0, max_score_super=1.0, device='cuda', model_cache_dir='./dataflow_cache', max_length=512):
        # Initialize operators
        self.deita_filter = DeitaQualityFilter(min_score=min_score_deita, max_score=max_score_deita, device=device, model_cache_dir=model_cache_dir, max_length=max_length)
        self.super_filter = SuperfilteringFilter(min_score=min_score_super, max_score=max_score_super, device=device, model_cache_dir=model_cache_dir, max_length=max_length)

    def run(self, storage):
        # Sequential calls to operators
        self.deita_filter.run(storage.step(), input_instruction_key='instruction', input_output_key='output', output_key='DeitaQualityScore')
        self.super_filter.run(storage.step(), input_instruction_key='instruction', input_input_key='input', input_output_key='output', output_key='SuperfilteringScore')

# Setup storage
